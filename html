            </a>
            <a href="https://portalrh.claro.com.br/ords/rhportal/rhlgweb.show" target="_blank" class="icon-card">
                <i>👥</i> <span>Portal RH</span> <small>recursos humanos</small>
            </a>
            <a href="https://hdim.fa.us2.oraclecloud.com/hcmUI/faces/FuseWelcome?_adf.ctrl-state=eqvx7jj5m_142&fnd=%3B%3B%3B%3Bfalse%3B256%3B%3B%3B&_afrLoop=3873689643141437" target="_blank" class="icon-card">
                <i>📚</i> <span>Trilhas</span> <small>Oracle HCM</small>
            </a>
            <a href="https://clarobr.atlassian.net/servicedesk/customer/user/login?destination=portals" target="_blank" class="icon-card">
                <i>🎫</i> <span>Jira</span> <small>service desk</small>
            </a>
        </div>
    </div>

    <!-- Conteúdo Ferramentas (links principais do fluxo) -->
    <div id="ferramentas" class="tab-pane">
        <div class="grid-icons">
            <a href="https://pontodigital.claro.com.br/entrar" target="_blank" class="icon-card">
                <i>🕒</i> <span>Bater Ponto</span> <small>início expediente</small>
            </a>
            <a href="https://nlsoarez.github.io/divisao-equipe-madrugada/" target="_blank" class="icon-card">
                <i>📅</i> <span>Calendário</span> <small>divisão do dia</small>
            </a>
            <a href="https://lirapin.github.io/comunicador-de-falhas/" target="_blank" class="icon-card">
                <i>⚠️</i> <span>Comunicador</span> <small>registro de falhas</small>
            </a>
            <a href="https://lirapin.github.io/gerador-de-mensagens/" target="_blank" class="icon-card">
