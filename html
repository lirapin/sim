            </a>
            <a href="https://dashboard-indicadores-cop-production.up.railway.app/" target="_blank" class="icon-card">
                <i>📊</i> <span>Indicadores</span> <small>dashboard COP</small>
            </a>
        </div>

        <!-- Fluxo diário / passo a passo implícito -->
        <div class="workflow-steps">
            <div class="steps-container">
                <div class="step-item">
                    <a href="https://pontodigital.claro.com.br/entrar" target="_blank">
                        <div class="step-number">1</div>
