            </div>
        </div>
    </div>

    <div class="footer">
        SIM - Sistema Integrado Madrugada • operação mais ágil e organizada
    </div>
</div>

<script>
    // Controle de abas
    const tabs = document.querySelectorAll('.tab-btn');
    const panes = document.querySelectorAll('.tab-pane');

    tabs.forEach(btn => {
        btn.addEventListener('click', () => {
            const tabId = btn.getAttribute('data-tab');
            // remove active de todos botões
            tabs.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            // esconde todos os pains e mostra o atual
            panes.forEach(pane => pane.classList.remove('active-pane'));
            document.getElementById(tabId).classList.add('active-pane');
        });
    });
</script>
</body>
</html>
