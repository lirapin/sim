    </div>

    <!-- Conteúdo Portais -->
    <div id="portais" class="tab-pane">
        <div class="grid-icons">
            <a href="http://10.29.5.216/scr/ui-newsletter.php" target="_blank" class="icon-card">
                <i>📰</i> <span>SCR</span> <small>Newsletter</small>
            </a>
            <a href="https://pontodigital.claro.com.br/login" target="_blank" class="icon-card">
