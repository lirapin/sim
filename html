                        <div class="step-desc">início do turno</div>
                    </a>
                </div>
                <div class="step-item">
                    <a href="https://nlsoarez.github.io/divisao-equipe-madrugada/" target="_blank">
                        <div class="step-number">2</div>
                        <i>📅</i>
                        <span>Ver calendário</span>
